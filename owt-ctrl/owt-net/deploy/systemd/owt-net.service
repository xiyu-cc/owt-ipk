[Unit]
Description=owt-net control plane service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
StateDirectory=owt-net
WorkingDirectory=/var/lib/owt-net
ExecStart=/usr/sbin/owt-net /etc/owt-net/config.ini
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
